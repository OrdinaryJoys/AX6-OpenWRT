#!/bin/sh
# AX6 WiFi max performance tuning — IPQ8074 4x4 AX, US FCC default
# Override country: echo CN > /etc/config/ax6_wifi_country && reboot
# Runs once via uci-defaults on first boot only.

COUNTRY_FILE="/etc/config/ax6_wifi_country"
COUNTRY="US"
if [ -r "$COUNTRY_FILE" ]; then
    COUNTRY="$(head -n 1 "$COUNTRY_FILE" | tr -d '[:space:]' | tr '[:lower:]' '[:upper:]')"
fi
[ -n "$COUNTRY" ] || COUNTRY="US"

RADIOS="$(uci show wireless 2>/dev/null | awk -F'[.=]' '/=wifi-device/{print $2}')"

for radio in $RADIOS; do
    band="$(uci -q get "wireless.${radio}.band")"

    # Country + explicit max TX power (hardware calibration may cap actual output)
    uci -q set "wireless.${radio}.country=$COUNTRY"
    uci -q set "wireless.${radio}.txpower=30"
    uci -q set "wireless.${radio}.disabled=0"

    # Coverage-optimized (sparse cell, legacy rates, weak-client RX)
    uci -q set "wireless.${radio}.cell_density=0"
    uci -q set "wireless.${radio}.legacy_rates=1"
    uci -q set "wireless.${radio}.noscan=1"
    uci -q set "wireless.${radio}.beacon_int=100"
    uci -q set "wireless.${radio}.dtim_period=1"

    # HE / Wi-Fi 6 full capability
    uci -q set "wireless.${radio}.he_su_beamformer=1"
    uci -q set "wireless.${radio}.he_su_beamformee=1"
    uci -q set "wireless.${radio}.he_mu_beamformer=1"
    uci -q set "wireless.${radio}.mu_beamformer=1"
    uci -q set "wireless.${radio}.he_mu_edca=1"
    uci -q set "wireless.${radio}.he_bss_color=8"
    uci -q set "wireless.${radio}.he_twt_required=0"
    uci -q set "wireless.${radio}.he_spr_sr_control=1"
    uci -q set "wireless.${radio}.he_spr_non_srg_obss_pd_max_offset=3"
    uci -q set "wireless.${radio}.he_default_pe_duration=4"

    # Band-specific channel & antenna
    case "$band" in
        5g)
            uci -q set "wireless.${radio}.htmode=HE80"
            cur_chan="$(uci -q get "wireless.${radio}.channel")"
            if [ -z "$cur_chan" ] || [ "$cur_chan" = "auto" ]; then
                uci -q set "wireless.${radio}.channel=149"  # UNII-3: max power, no DFS
            fi
            uci -q set "wireless.${radio}.tx_antenna=15"   # 4x4
            uci -q set "wireless.${radio}.rx_antenna=15"
            ;;
        2g)
            uci -q set "wireless.${radio}.htmode=HE40"
            uci -q set "wireless.${radio}.channel=auto"
            uci -q set "wireless.${radio}.tx_antenna=3"    # 2x2
            uci -q set "wireless.${radio}.rx_antenna=3"
            ;;
    esac

    # 802.11k/v/r fast roaming
    uci -q set "wireless.${radio}.ieee80211k=1"
    uci -q set "wireless.${radio}.ieee80211v=1"
    uci -q set "wireless.${radio}.ieee80211r=0"           # FT needs shared NAS key
    uci -q set "wireless.${radio}.bss_transition=1"
    uci -q set "wireless.${radio}.rrm_neighbor_report=1"
    uci -q set "wireless.${radio}.rrm_beacon_report=1"

    # Link-layer max throughput
    uci -q set "wireless.${radio}.short_gi_20=1"
    uci -q set "wireless.${radio}.short_gi_40=1"
    uci -q set "wireless.${radio}.short_gi_80=1"
    uci -q set "wireless.${radio}.short_gi_160=1"
    uci -q set "wireless.${radio}.tx_stbc_2by1=1"
    uci -q set "wireless.${radio}.rx_stbc=3"
    uci -q set "wireless.${radio}.ldpc=1"
    uci -q set "wireless.${radio}.greenfield=0"           # keep 11n/g compatibility
    uci -q set "wireless.${radio}.max_amsdu=1"
    uci -q set "wireless.${radio}.dsss_cck_40=1"
done

# Per-interface settings — only non-encryption experience items
for iface in $(uci show wireless 2>/dev/null | awk -F'[.=]' '/=wifi-iface/{print $2}'); do
    uci -q set "wireless.${iface}.disassoc_low_ack=0"     # don't kick weak-signal clients
    uci -q set "wireless.${iface}.wmm=1"                  # WMM QoS
    uci -q set "wireless.${iface}.uapsd=1"                # U-APSD power save
    uci -q set "wireless.${iface}.proxy_arp=1"            # reduce broadcast ARP
    uci -q set "wireless.${iface}.multicast_to_unicast=1"
    if [ -z "$(uci -q get "wireless.${iface}.ieee80211w")" ]; then
        uci -q set "wireless.${iface}.ieee80211w=1"       # PMF optional
    fi
done

uci -q commit wireless
exit 0
