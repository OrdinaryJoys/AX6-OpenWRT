#!/bin/sh
# NSS 加速 + 网络栈调优，AX6 1G 内存安全值
# 失败也不影响 boot
set +e

# ---- BBR 兜底：模块存在才启用，避免静默失败 ----
BBR_AVAILABLE=0
if modprobe tcp_bbr 2>/dev/null; then
    echo 'tcp_bbr' > /etc/modules.d/30-tcp-bbr
    BBR_AVAILABLE=1
fi

# ---- 写入 sysctl 调优 ----
cat >> /etc/sysctl.conf <<'EOF'

# ---- NSS / 转发性能 ----
net.core.rps_sock_flow_entries=32768
net.core.netdev_max_backlog=16384
net.core.somaxconn=4096

# 连接跟踪表（NAT 大量并发场景）
net.netfilter.nf_conntrack_max=65536
net.netfilter.nf_conntrack_tcp_timeout_established=7440
net.netfilter.nf_conntrack_buckets=16384

# TCP buffer（千兆 WAN 够用，不撑爆 1G 内存）
net.core.rmem_max=8388608
net.core.wmem_max=8388608
net.ipv4.tcp_rmem=4096 87380 8388608
net.ipv4.tcp_wmem=4096 65536 8388608
net.ipv4.tcp_fastopen=3

# 桥接：NSS 已接管转发，关掉 br_netfilter 钩子避免双层处理
# 注意：用 OpenClash/PassWall 透明代理 fake-ip 模式时要改回 1
net.bridge.bridge-nf-call-iptables=0
net.bridge.bridge-nf-call-ip6tables=0
EOF

# 只有 BBR 可用才追加 BBR 配置
if [ "$BBR_AVAILABLE" = "1" ]; then
    cat >> /etc/sysctl.conf <<'EOF'

# BBR 拥塞控制（仅影响路由器自身 TCP，转发流量走 NSS 不受影响）
net.ipv4.tcp_congestion_control=bbr
net.core.default_qdisc=fq
EOF
fi

# 立即生效（缺失的 key 只 warning，不报错）
sysctl -p >/dev/null 2>&1

# ---- 关闭 firewall flow_offloading，避免和 NSS 双卸载冲突 ----
uci -q set firewall.@defaults[0].flow_offloading='0'
uci -q set firewall.@defaults[0].flow_offloading_hw='0'
uci commit firewall

exit 0
