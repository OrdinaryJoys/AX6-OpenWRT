#!/bin/sh /etc/rc.common
# AX6 Boot Guard — 每次启动强制执行关键 NSS/WiFi 安全设置
# 防止 sysupgrade 保留配置时 uci-defaults 跳过导致的配置泄漏
START=11

start() {
    # 1. packet_steering 必须 =0 (NSS 硬件卸载需要)
    cur=$(uci -q get network.globals.packet_steering 2>/dev/null)
    [ "$cur" != "0" ] && uci set network.globals.packet_steering='0' && CHANGED=1

    # 2. 所有 device 级别 offload 禁止
    for d in $(uci -q show network 2>/dev/null | awk -F'[.=]' '/=device$/{print $2}'); do
        [ "$(uci -q get "network.${d}.packet_steering")" != "0" ] && uci -q set "network.${d}.packet_steering=0" && CHANGED=1
        [ "$(uci -q get "network.${d}.flow_offloading")" != "0" ] && uci -q set "network.${d}.flow_offloading=0" && CHANGED=1
        [ "$(uci -q get "network.${d}.flow_offloading_hw")" != "0" ] && uci -q set "network.${d}.flow_offloading_hw=0" && CHANGED=1
    done

    # 3. vlan_filtering 必须 !=1 (NSS WiFi 不兼容)
    for d in $(uci -q show network 2>/dev/null | awk -F'[.=]' '/=device$/{print $2}'); do
        [ "$(uci -q get "network.${d}.vlan_filtering")" = "1" ] && uci -q set "network.${d}.vlan_filtering=0" && CHANGED=1
    done

    # 4. bridge-vlan 段不应存在
    if uci -q show network 2>/dev/null | grep -q '=bridge-vlan'; then
        for section in $(uci -q show network 2>/dev/null | awk -F'[.=]' '/=bridge-vlan/{print $2}'); do
            uci -q delete "network.${section}"
        done
        CHANGED=1
    fi

    # 5. 仅在检测到异常时提交 + 日志
    if [ "${CHANGED:-0}" = "1" ]; then
        uci commit network
        logger -t ax6-boot-guard "Corrected NSS-incompatible settings (likely from sysupgrade with preserved config)"
    fi

    # 6. Conntrack TCP timeout: 86400s (24h), 不被 11-nf-conntrack.conf (7440) 覆盖
    ECM_FILE="/etc/sysctl.d/qca-nss-ecm.conf"
    if [ -f "$ECM_FILE" ]; then
        cur_timeout=$(grep "tcp_timeout_established" "$ECM_FILE" 2>/dev/null | grep -o '[0-9]*')
        if [ "${cur_timeout:-0}" != "86400" ]; then
            if grep -q "tcp_timeout_established" "$ECM_FILE"; then
                sed -i "s/.*tcp_timeout_established=.*/net.netfilter.nf_conntrack_tcp_timeout_established=86400/" "$ECM_FILE"
            else
                echo "net.netfilter.nf_conntrack_tcp_timeout_established=86400" >> "$ECM_FILE"
            fi
            sysctl -p "$ECM_FILE" >/dev/null 2>&1
            logger -t ax6-boot-guard "Corrected conntrack TCP timeout to 86400s"
        fi
    fi

    # 7. WiFi 国家码同步
    country=$(uci -q get wireless.radio0.country 2>/dev/null)
    [ -z "$country" ] && country="US"
    [ "$(iw reg get 2>/dev/null | awk '/country/{print $2; exit}' | tr -d ':')" != "$country" ] && iw reg set "$country" 2>/dev/null
}
