#!/bin/sh
# AX6 NSS / WiFi 健康自检工具
# 用法:
#   nss-check        简洁(只列 FAIL)
#   nss-check -v     详细(全部检查)
#   nss-check -q     静默,只输出 0/N 退出码(适合 cron)
# 退出码 = FAIL 数

VERBOSE=0
QUIET=0

case "${1:-}" in
    ""|"--")
        ;;
    -v|--verbose)
        VERBOSE=1
        ;;
    -q|--quiet)
        QUIET=1
        ;;
    -h|--help)
        sed -n '2,7p' "$0" | sed 's/^# //; s/^#//'
        exit 0
        ;;
    *)
        echo "nss-check: unknown option '$1' (use -v / -q / -h)" >&2
        exit 64
        ;;
esac

PASS=0
FAIL=0
WARN=0

ok() {
    PASS=$((PASS + 1))
    if [ "$VERBOSE" -eq 1 ] && [ "$QUIET" -eq 0 ]; then
        echo " ✓ $1"
    fi
}

fail() {
    FAIL=$((FAIL + 1))
    if [ "$QUIET" -eq 0 ]; then
        echo " ✗ $1"
    fi
}

warn() {
    WARN=$((WARN + 1))
    if [ "$VERBOSE" -eq 1 ] && [ "$QUIET" -eq 0 ]; then
        echo " ! $1"
    fi
}

if [ "$QUIET" -eq 0 ]; then
    echo "=== AX6 NSS / WiFi 健康自检 ==="
fi

# ---- 1. RAM ----
mem_kb=$(awk '/MemTotal/{print $2}' /proc/meminfo 2>/dev/null)
if [ -n "$mem_kb" ] && [ "$mem_kb" -gt 800000 ] 2>/dev/null; then
    ok "RAM detected: ${mem_kb} kB ≥ 800MB (1GB SKU)"
else
    fail "RAM only ${mem_kb:-?} kB < 800MB — 不是 1GB 高配 SKU,nss-extra.config 配置可能不匹配"
fi

# ---- 2. NAND 大小 ----
mtd12_size=$(awk -F'[: ]+' '/^mtd12:/{print $2}' /proc/mtd 2>/dev/null)
case "$mtd12_size" in
    06640000)
        ok "NAND rootfs: 102 MiB (stock layout)"
        ;;
    0[Cc]000000)
        ok "NAND rootfs: 192 MiB (expand layout, modded NAND)"
        ;;
    *)
        warn "NAND rootfs size 0x${mtd12_size:-?} — 非典型"
        ;;
esac

# ---- 3. NSS 模块加载 ----
nss_count=$(lsmod | grep -c '^qca_nss')
if [ "$nss_count" -ge 10 ]; then
    ok "NSS 模块 loaded: $nss_count"
else
    fail "NSS 模块只 loaded $nss_count(应 ≥10)"
fi

# ---- 4. NSS Core 启动 ----
_dmesg=$(dmesg 2>/dev/null)
if echo "$_dmesg" | grep -q "NSS core .* booted"; then
    cores=$(echo "$_dmesg" | grep -c "NSS core .* booted")
    ok "NSS Core(s) booted: $cores"
else
    fail "NSS Core 未启动 — 查 dmesg | grep -i 'nss\\|ubi32'"
fi

# ---- 5. NSS clock auto_scale 锁定 ----
auto_scale=$(sysctl -n dev.nss.clock.auto_scale 2>/dev/null)
if [ "$auto_scale" = "0" ]; then
    ok "NSS clock auto_scale = 0 (locked at max)"
else
    warn "NSS clock auto_scale = ${auto_scale:-unset}"
fi

# ---- 6. ath11k 加载 ----
if lsmod | grep -q ath11k; then
    ok "ath11k driver loaded"
else
    fail "ath11k driver 未加载"
fi

# ---- 7. ath11k board file 加载 ----
if echo "$_dmesg" | grep -qE "ath11k.*board.*Redmi-AX6"; then
    ok "ath11k board-2.bin: Redmi-AX6 calibration variant loaded"
else
    warn "未在 dmesg 找到 'Redmi-AX6' calibration 字样(可能仍 OK,看 dmesg | grep ath11k)"
fi

# ---- 8. ath11k fw memory mode ----
# AX6 (1GB RAM) 使用 MID 模式 (mode=1):
#   FULL (mode=0) 需要 ~100MB DMA 连续内存,CMA 不足时固件加载失败 → 内核 panic
#   MID (mode=1) ~32MB 内存占用,稳定且性能足够家用 4×4 MU-MIMO 场景
# (dmesg 格式 "FW memory mode: N")
fw_mode=$(echo "$_dmesg" | grep -oE "FW memory mode:[[:space:]]*[0-9]+" | tail -n 1 | grep -oE "[0-9]+")
case "$fw_mode" in
    1)
        ok "ath11k fw_mem_mode = 1 (MID, 与 DTS qcom,ath11k-fw-memory-mode=<1> 匹配)"
        ;;
    0)
        warn "ath11k fw_mem_mode = 0 (FULL/HIGH; 期望 1=MID,可能 CMA 不足时仍能跑)"
        ;;
    2)
        fail "ath11k fw_mem_mode = 2 (LOW); 期望 1=MID,启动序列异常"
        ;;
    "")
        warn "未读到 fw_mem_mode"
        ;;
    *)
        warn "ath11k fw_mem_mode = $fw_mode (期望 1=MID)"
        ;;
esac

# ---- 9. 防火墙 flow_offload 内核模块必须关 ----
# (firewall4 使用 nftables, UCI flow_offloading 选项不存在;
#  直接检查内核冲突模块是否被加载)
if lsmod | grep -Eq '^(nf_flow_table|nft_flow_offload|ipt_FLOWOFFLOAD) ' 2>/dev/null; then
    fail "Conflicting flow-offload kernel module loaded — rmmod + check /etc/modprobe.d/nss-no-flow.conf"
else
    ok "No conflicting flow-offload kernel modules (NSS ECM handles offload)"
fi

# ---- 10. ECM connection_count(NSS 工作中应 > 0)----
ecm_path="/sys/kernel/debug/ecm/ecm_db/connection_count_simple"
if [ -r "$ecm_path" ]; then
    cc=$(cat "$ecm_path")
    if [ "${cc:-0}" -gt 0 ] 2>/dev/null; then
        ok "ECM connection_count = $cc (NSS 正在卸载流量)"
    else
        warn "ECM connection_count = 0 (没流量?跑 ping/curl 后再测)"
    fi
else
    warn "ECM debugfs 不可读($ecm_path — 是否 mounted?)"
fi

# ---- 11. WiFi 工作模式 ----
if iw dev 2>/dev/null | grep -qE "channel.*MHz.*width: (80|160)"; then
    ok "WiFi 5G HE80/HE160 active"
elif iw dev 2>/dev/null | grep -q "channel.*MHz"; then
    warn "WiFi 已起,但不是 HE80/HE160(可能 client 不支持或 DFS 频段)"
else
    fail "WiFi 没工作"
fi

# ---- 12. Country code ----
cc_get=$(iw reg get 2>/dev/null | awk '/country/{print $2; exit}' | tr -d ':')
if [ -n "$cc_get" ]; then
    ok "Regulatory: country=$cc_get"
fi

# ---- 13. NSS frame_mode 检查(关键的 NSS-redirect 入口)----
fm_path="/sys/module/ath11k/parameters/frame_mode"
if [ -r "$fm_path" ]; then
    fm=$(cat "$fm_path")
    case "$fm" in
        2) ok "ath11k frame_mode=2 (NSS_DP, 满血卸载)" ;;
        1) warn "ath11k frame_mode=1 (RAW, 部分加速)" ;;
        0) fail "ath11k frame_mode=0 (NATIVE, NSS 旁路!)" ;;
        *) warn "ath11k frame_mode=$fm 未知" ;;
    esac
fi

# ---- 14. VLAN 配置兼容性(qosmio 强制要求)----
# bridge_vlan_filtering 与 NSS WiFi 不兼容 — 应该 unset 或 =0
vf_violation=0
for d in $(uci -q show network 2>/dev/null | awk -F'[.=]' '/=device$/{print $2}'); do
    if [ "$(uci -q get "network.${d}.vlan_filtering")" = "1" ]; then
        fail "network.$d.vlan_filtering=1 与 NSS 不兼容!运行: uci del network.$d.vlan_filtering && uci commit network && reboot"
        vf_violation=1
    fi
done
if [ "$vf_violation" -eq 0 ]; then
    ok "无 bridge_vlan_filtering=1 (NSS 兼容)"
fi

# bridge-vlan 段不应存在
if uci -q show network 2>/dev/null | grep -q '=bridge-vlan'; then
    fail "/etc/config/network 中存在 'bridge-vlan' 段(DSA 语法,与 NSS 不兼容);改用 8021q 子接口 vlan-add"
else
    ok "无 'bridge-vlan' 段配置 (NSS 兼容)"
fi

# 8021q kmod 加载
if lsmod | grep -q "^8021q "; then
    ok "kmod-8021q 已加载(VLAN tagging 可用)"
else
    warn "kmod-8021q 未加载;如需 VLAN 用 'modprobe 8021q' 或 'vlan-add' 助手"
fi

# qca-nss-drv-vlan-mgr 加载
if lsmod | grep -q "^qca_nss_vlan_mgr "; then
    ok "qca-nss-drv-vlan-mgr 已加载(NSS VLAN 卸载就绪)"
else
    warn "qca-nss-drv-vlan-mgr 未加载;无 VLAN 时无影响"
fi

if [ "$QUIET" -eq 0 ]; then
    echo ""
    echo "=== 汇总: PASS=$PASS  WARN=$WARN  FAIL=$FAIL ==="
    if [ "$FAIL" -eq 0 ]; then
        echo "状态: ✓ 健康"
    else
        echo "状态: ✗ 有问题,看上面 FAIL 项"
    fi
fi
exit "$FAIL"


