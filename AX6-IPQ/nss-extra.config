###########################################################################
# NSS 满血 + 零冲突 + WiFi 完整特性
# 由 build workflow `cat >> openwrt/.config` 应用
# 实测硬件:1 GB DDR + 128 MB NAND(stock)/ 256 MB NAND(expand)
#
# 本文件仅包含:
#   1. NSS 互斥项(=n 安全网)  — 即使基础配置有误也会覆盖
#   2. .config-stock 中未包含的必要补充
# 与 .config-stock 重复的 =y 不再列出,避免双重维护。
###########################################################################

# ========================================================================
# 1. NSS 互斥安全网 — 强制 =n,防止 defconfig 或其他 select 拉回
# ========================================================================
CONFIG_PACKAGE_kmod-nf-flow=n
CONFIG_PACKAGE_kmod-ipt-offload=n
CONFIG_PACKAGE_kmod-nft-offload=n
CONFIG_PACKAGE_kmod-fast-classifier=n
CONFIG_PACKAGE_kmod-shortcut-fe=n
CONFIG_PACKAGE_kmod-shortcut-fe-cm=n
# 防御:kmod-iptables 是 HIDDEN 旧 legacy 包,与 kmod-nf-ipt 提供同样的 .ko;
# nss-fork b0c5bf38 已删除 kmod-nf-ipt 的错误依赖让两者不再冲突,这里再用
# =n 兜底,防止未来上游回归把它拉回来。
CONFIG_PACKAGE_kmod-iptables=n
CONFIG_PACKAGE_sqm-scripts-nss=n
CONFIG_PACKAGE_sqm-scripts=n
CONFIG_PACKAGE_kmod-sched-cake=n
CONFIG_KERNEL_MPTCP=n
CONFIG_KERNEL_NETKIT=n
CONFIG_PACKAGE_MAC80211_MESH=n
CONFIG_ATH11K_NSS_MESH_SUPPORT=n
CONFIG_PACKAGE_kmod-qca-nss-drv-wifi-meshmgr=n
CONFIG_ATH11K_THERMAL=n

# ========================================================================
# 2. NSS 驱动特性标志 (覆盖 .config-stock 中的默认 =n)
# ========================================================================
CONFIG_NSS_DRV_MAPT_ENABLE=y
CONFIG_NSS_DRV_TUN6RD_ENABLE=y
CONFIG_NSS_DRV_TUNIPIP6_ENABLE=y
CONFIG_NSS_DRV_VXLAN_ENABLE=y

# ========================================================================
# 3. VLAN (8021q) — qosmio NSS 兼容 VLAN 方案
# ========================================================================
CONFIG_PACKAGE_kmod-8021q=y
# CONFIG_PACKAGE_vlan is not set (legacy 包,DSA 下不需要;vconfig 由 busybox ip link 替代)
CONFIG_PACKAGE_kmod-mii=y

# ========================================================================
# 4. NSS 流量整形 + QoS
# ========================================================================
CONFIG_PACKAGE_kmod-qca-nss-drv-shaper=y

# ========================================================================
# 5. qca-ssdk 补充 (必需) — kmod-qca-rfs/kmod-qca-pppe 已由 NSS 6.18 内置
# ========================================================================

# ========================================================================
# 6. WiFi 补充 — wpad + NSS redirect
# ========================================================================
CONFIG_PACKAGE_wpad-openssl=y
CONFIG_PACKAGE_MAC80211_NSS_SUPPORT=y
CONFIG_PACKAGE_MAC80211_NSS_REDIRECT=y

# ========================================================================
# 7. CPU 优化
# ========================================================================
# 网络调优:
#   - RPS/XPS 已由 target/linux/qualcommax/config-6.18 默认开启
#   - BBR 由 .config-stock 的 CONFIG_PACKAGE_kmod-tcp-bbr=y 提供;
#     运行时切换由 sysctl.d/99-ax6-tune.conf 的 net.ipv4.tcp_congestion_control 完成
#   - 串口 console 由 u-boot 通过 DTB chosen.bootargs 传递,
#     OpenWrt 无 CONFIG_KERNEL_CMDLINE 包装器,直接写 CONFIG_CMDLINE 无效
CONFIG_TARGET_OPTIMIZATION="-Os -pipe -mcpu=cortex-a53+crc+crypto"

# ========================================================================
# 8. 调试关闭 — 生产固件
# ========================================================================
# CONFIG_ATH11K_DEBUG is not set
# CONFIG_NSS_DRV_DEBUG is not set
# CONFIG_ATH11K_DEBUGFS is not set
# CONFIG_ATH11K_DEBUGFS_STA is not set
# CONFIG_ATH11K_DEBUGFS_HTT_STATS is not set
# CONFIG_ATH11K_TRACING is not set
# CONFIG_ATH11K_SPECTRAL is not set

# ========================================================================
# 9. 内核诊断 — 启动失败时可从串口获取可用日志
# ========================================================================
CONFIG_KERNEL_SOFTLOCKUP_DETECTOR=y
CONFIG_KERNEL_DETECT_HUNG_TASK=y
CONFIG_KERNEL_PRINTK_TIME=y
