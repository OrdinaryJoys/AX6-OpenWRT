###########################################################################
# NSS 满血 + 零冲突 + WiFi 完整特性
# 由 build workflow `cat >> openwrt/.config` 应用
# 实测硬件:1 GB DDR + 128 MB NAND(stock)/ 256 MB NAND(expand)
###########################################################################

# ========================================================================
# 1. 互斥项 — 必须关掉,否则 NSS 启动失败或双卸载冲突
# ========================================================================
CONFIG_PACKAGE_kmod-nf-flow=n
CONFIG_PACKAGE_kmod-ipt-offload=n
CONFIG_PACKAGE_kmod-fast-classifier=n
CONFIG_PACKAGE_kmod-shortcut-fe=n
CONFIG_PACKAGE_kmod-shortcut-fe-cm=n
CONFIG_PACKAGE_sqm-scripts=n          # 用 sqm-scripts-nss 替代
CONFIG_PACKAGE_kmod-sched-cake=n      # NSS shaper 替代
CONFIG_KERNEL_MPTCP=n                 # NSS 不支持 MPTCP
CONFIG_KERNEL_NETKIT=n                # 实验性,NSS 不识别

# ========================================================================
# 2. NSS 核心 + ECM(必需)
# ========================================================================
CONFIG_PACKAGE_kmod-qca-nss-drv=y
CONFIG_PACKAGE_kmod-qca-nss-dp=y
CONFIG_PACKAGE_kmod-qca-nss-ecm=y
CONFIG_PACKAGE_kmod-qca-nss-crypto=y
CONFIG_PACKAGE_kmod-qca-nss-macsec=y
CONFIG_PACKAGE_kmod-qca-nss-nft=y

# NSS 协议卸载(全开)
CONFIG_PACKAGE_kmod-qca-nss-drv-bridge-mgr=y
CONFIG_PACKAGE_kmod-qca-nss-drv-vlan-mgr=y
CONFIG_PACKAGE_kmod-qca-nss-drv-lag-mgr=y
CONFIG_PACKAGE_kmod-qca-nss-drv-pppoe=y
CONFIG_PACKAGE_kmod-qca-nss-drv-pptp=y
CONFIG_PACKAGE_kmod-qca-nss-drv-l2tpv2=y
CONFIG_PACKAGE_kmod-qca-nss-drv-gre=y
CONFIG_PACKAGE_kmod-qca-nss-drv-tun6rd=y
CONFIG_PACKAGE_kmod-qca-nss-drv-tunipip6=y
CONFIG_PACKAGE_kmod-qca-nss-drv-map-t=y
CONFIG_PACKAGE_kmod-qca-nss-drv-vxlanmgr=y
# 关 mesh:家用单 AP 不需要 802.11s,且与新 firmware 12.5 互斥
CONFIG_PACKAGE_kmod-qca-nss-drv-wifi-meshmgr=n
CONFIG_PACKAGE_kmod-qca-nss-drv-igs=y

# ========================================================================
# VLAN(8021q tagging,与 NSS 完美兼容的方案)
# qosmio 强制要求:必须用 8021q 子接口(lan1.20),不能用 bridge_vlan_filtering
# 详见 https://github.com/qosmio/openwrt-ipq/blob/main-nss/nss-setup/example/README.md
# ========================================================================
# 8021q VLAN 子接口支持
CONFIG_PACKAGE_kmod-8021q=y
# vlan 用户态工具
CONFIG_PACKAGE_vlan=y
# MII PHY 接口(VLAN 依赖)
CONFIG_PACKAGE_kmod-mii=y
CONFIG_PACKAGE_kmod-qca-nss-drv-qdisc=y
CONFIG_PACKAGE_kmod-qca-nss-drv-shaper=y
CONFIG_PACKAGE_kmod-qca-nss-drv-mirror=y
CONFIG_PACKAGE_kmod-qca-nss-drv-match=y

# qca-ssdk + RFS(必需)
CONFIG_PACKAGE_kmod-qca-ssdk-nohnat=y
CONFIG_PACKAGE_kmod-qca-rfs=y
CONFIG_PACKAGE_kmod-qca-pppe=y
CONFIG_PACKAGE_kmod-nss-ifb=y

# ========================================================================
# 3. NSS 内存配置 — 已在 .config-stock/.config-expand 中设置,此处不重复
# (重复设置会导致 Kconfig choice 冲突警告,见 build log)
# ========================================================================

# ========================================================================
# 4. WiFi:ath11k 完整 NSS 集成 (Wi-Fi 6 4x4 满血)
# ========================================================================
CONFIG_PACKAGE_ipq-wifi-redmi_ax6=y
CONFIG_PACKAGE_kmod-ath11k=y
CONFIG_PACKAGE_kmod-ath11k-ahb=y
CONFIG_PACKAGE_kmod-ath11k-pci=y
CONFIG_PACKAGE_MAC80211_NSS_REDIRECT=y
CONFIG_PACKAGE_ATH11K_NSS_SUPPORT=y

# ath11k 调优(NSS 集成 + 1GB profile + 2048 TX queue)
CONFIG_ATH11K_NSS_SUPPORT=y
# 关 mesh / 4addr:家用单 AP 不用 802.11s,且 NSS firmware 12.5 不支持 mesh
CONFIG_ATH11K_NSS_MESH_SUPPORT=n
CONFIG_ATH11K_NSS_TX_SUPPORT=y
CONFIG_ATH11K_NSS_4ADDR_SUPPORT=n
CONFIG_ATH11K_TX_QUEUE_SIZE=2048
# CONFIG_ATH11K_MEM_PROFILE_1G 已在 .config-stock 中设置,不重复
CONFIG_ATH11K_NAPI_WEIGHT_512=y       # 高性能 NAPI 权重

# 关闭 ath11k 温度监控:qosmio 推荐(NSS firmware 模式下 thermal sysfs
# 可能与 firmware 冲突;实测 NSS Core 自带温度防护)
# 参考:https://github.com/qosmio/openwrt-ipq/blob/main-nss/nss-setup/config-nss.seed
CONFIG_ATH11K_THERMAL=n

# 调试关闭(节省体积,生产用)
# CONFIG_ATH11K_DEBUGFS is not set
# CONFIG_ATH11K_DEBUGFS_STA is not set
# CONFIG_ATH11K_DEBUGFS_HTT_STATS is not set
# CONFIG_ATH11K_TRACING is not set
# CONFIG_ATH11K_SPECTRAL is not set

# ========================================================================
# 5. 内核多核 / SoftIRQ 分流(NSS 客户端 CPU 利用)
# ========================================================================
CONFIG_KERNEL_RPS=y
CONFIG_KERNEL_RFS=y
CONFIG_KERNEL_XPS=y
CONFIG_KERNEL_SKB_RECYCLER=y
CONFIG_KERNEL_SKB_RECYCLER_MULTI_CPU=y
CONFIG_KERNEL_SKB_RECYCLER_PREALLOC=y
CONFIG_KERNEL_HZ_1000=y
# 内核抢占模型: 必须为 NONE!
# qosmio NSS-12.5 驱动要求 PREEMPT_NONE,完全抢占(PREEMPT)会导致
# NSS 共享内存竞态→固件消息损坏→看门狗超时→内核 panic→反复重启
# .config-stock 已设 PREEMPT_NONE,此处显式确认不加 PREEMPT
# CONFIG_KERNEL_PREEMPT is not set
CONFIG_KERNEL_CGROUPS=y
CONFIG_KERNEL_CGROUP_SCHED=y
CONFIG_KERNEL_FAIR_GROUP_SCHED=y
CONFIG_KERNEL_CFS_BANDWIDTH=y
CONFIG_KERNEL_NET_L3_MASTER_DEV=y

# ========================================================================
# 6. 拥塞 / qdisc(BBR + fq + NSS shaper)
# ========================================================================
CONFIG_KERNEL_TCP_CONG_BBR=y
CONFIG_DEFAULT_TCP_CONG="bbr"

# ========================================================================
# 7. NSS Firmware 版本 — 12.5 Release 210(2025-05,**性能最优**)
#    11.4 仅为 802.11s mesh 兼容保留;家用单路由用 12.5 更快
# ========================================================================
CONFIG_NSS_FIRMWARE_VERSION_12_5=y
# CONFIG_NSS_FIRMWARE_VERSION_12_2 is not set
# CONFIG_NSS_FIRMWARE_VERSION_12_1 is not set
# CONFIG_NSS_FIRMWARE_VERSION_11_4 is not set

# ========================================================================
# 8. 系统体积控制 — rootfs 仅 102MB(stock)/ 210MB(expand),严禁开 debug
# ========================================================================
CONFIG_KERNEL_PRINTK_TIME=y
# CONFIG_KERNEL_DEBUG_INFO is not set
# CONFIG_KERNEL_DEBUG_INFO_REDUCED is not set
# CONFIG_KERNEL_FTRACE is not set
# CONFIG_KERNEL_FUNCTION_TRACER is not set
# CONFIG_KERNEL_FUNCTION_GRAPH_TRACER is not set
# CONFIG_KERNEL_DYNAMIC_FTRACE is not set
# CONFIG_KERNEL_TRACING is not set
